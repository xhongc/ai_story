{
  "_meta": {
    "binding_id": "t2i_lora_style",
    "workflow_profile": "minimal",
    "description": "Z-Image Turbo + LoRA 风格化模板；当前默认接入远端已可见的 pixel_art_style_z_image_turbo LoRA。"
  },
  "prompt": {
    "1": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "z_image_turbo_bf16.safetensors",
        "weight_dtype": "default"
      }
    },
    "2": {
      "class_type": "CLIPLoader",
      "inputs": {
        "clip_name": "qwen_3_4b.safetensors",
        "type": "qwen_image",
        "device": "default"
      }
    },
    "3": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "ae.safetensors"
      }
    },
    "4": {
      "class_type": "TextEncodeZImageOmni",
      "inputs": {
        "clip": [
          "10",
          1
        ],
        "prompt": "修仙宗门夜色像素风场景，灯火点亮山门与楼阁，8bit inspired pixel art style",
        "auto_resize_images": true
      }
    },
    "5": {
      "class_type": "TextEncodeZImageOmni",
      "inputs": {
        "clip": [
          "10",
          1
        ],
        "prompt": "模糊，低清晰度，水印，logo，脏噪点，结构崩坏",
        "auto_resize_images": true
      }
    },
    "6": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 1024,
        "height": 1024,
        "batch_size": 1
      }
    },
    "7": {
      "class_type": "KSampler",
      "inputs": {
        "model": [
          "10",
          0
        ],
        "seed": 42,
        "steps": 8,
        "cfg": 1.0,
        "sampler_name": "euler",
        "scheduler": "simple",
        "positive": [
          "4",
          0
        ],
        "negative": [
          "5",
          0
        ],
        "latent_image": [
          "6",
          0
        ],
        "denoise": 1.0
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": [
          "7",
          0
        ],
        "vae": [
          "3",
          0
        ]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "images": [
          "8",
          0
        ],
        "filename_prefix": "z_image_lora_style"
      }
    },
    "10": {
      "class_type": "LoraLoader",
      "inputs": {
        "model": [
          "1",
          0
        ],
        "clip": [
          "2",
          0
        ],
        "lora_name": "pixel_art_style_z_image_turbo.safetensors",
        "strength_model": 0.85,
        "strength_clip": 0.55
      }
    }
  }
}

